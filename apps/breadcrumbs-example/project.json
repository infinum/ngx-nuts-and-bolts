{
	"name": "breadcrumbs-example",
	"$schema": "../../node_modules/nx/schemas/project-schema.json",
	"projectType": "application",
	"prefix": "app",
	"sourceRoot": "apps/breadcrumbs-example/src",
	"tags": [],
	"targets": {
		"build": {
			"executor": "@angular/build:application",
			"outputs": ["{options.outputPath}"],
			"options": {
				"outputPath": "dist/apps/breadcrumbs-example",
				"browser": "apps/breadcrumbs-example/src/main.ts",
				"tsConfig": "apps/breadcrumbs-example/tsconfig.app.json",
				"inlineStyleLanguage": "scss",
				"assets": [
					{
						"glob": "**/*",
						"input": "apps/breadcrumbs-example/public"
					},
					"apps/breadcrumbs-example/src/favicon.ico",
					{
						"glob": "**/*",
						"input": "apps/breadcrumbs-example/src/assets",
						"output": "assets"
					},
					{
						"glob": "mockServiceWorker.js",
						"input": "libs/msw-public",
						"output": ""
					}
				],
				"styles": ["apps/breadcrumbs-example/src/styles.scss"],
				"allowedCommonJsDependencies": ["path-to-regexp"]
			},
			"configurations": {
				"production": {
					"budgets": [
						{
							"type": "initial",
							"maximumWarning": "600kb",
							"maximumError": "1mb"
						},
						{
							"type": "anyComponentStyle",
							"maximumWarning": "4kb",
							"maximumError": "8kb"
						}
					],
					"outputHashing": "all"
				},
				"development": {
					"optimization": false,
					"extractLicenses": false,
					"sourceMap": true
				}
			},
			"defaultConfiguration": "production"
		},
		"serve": {
			"continuous": true,
			"executor": "@angular/build:dev-server",
			"configurations": {
				"production": {
					"buildTarget": "breadcrumbs-example:build:production"
				},
				"development": {
					"buildTarget": "breadcrumbs-example:build:development"
				}
			},
			"defaultConfiguration": "development"
		},
		"lint": {
			"executor": "@nx/eslint:lint"
		},
		"test": {
			"executor": "@nx/jest:jest",
			"outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
			"options": {
				"jestConfig": "apps/breadcrumbs-example/jest.config.cts",
				"tsConfig": "apps/breadcrumbs-example/tsconfig.spec.json"
			}
		},
		"serve-static": {
			"continuous": true,
			"executor": "@nx/web:file-server",
			"options": {
				"buildTarget": "breadcrumbs-example:build",
				"staticFilePath": "dist/apps/breadcrumbs-example/browser",
				"spa": true
			}
		}
	}
}
